# ============================================================
# ToxiroAbogados — Variables de entorno para VPS (Dokploy)
# Copiar como .env.prod y llenar los valores
# NUNCA subir a Git con credenciales reales
# ============================================================

# === Base de datos PostgreSQL ===
DB_PASS_LEGAL=CAMBIAR_contraseña_segura_aqui

# === Directus ===
# Generar keys con: openssl rand -hex 32
DIRECTUS_KEY=CAMBIAR_generar_con_openssl_rand_hex_32
DIRECTUS_SECRET=CAMBIAR_generar_con_openssl_rand_hex_32
DIRECTUS_ADMIN_EMAIL=admin@toxirodigital.cloud
DIRECTUS_ADMIN_PASSWORD=CAMBIAR_contraseña_admin

# === Twilio WhatsApp (sandbox) ===
TWILIO_ACCOUNT_SID=AC2dd91dc7c1f67a1817bc7caab8823f4a
TWILIO_AUTH_TOKEN=CAMBIAR_twilio_auth_token
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# === Frontend (build-time, se inyecta en Dockerfile.frontend) ===
VITE_API_URL=https://api.toxirodigital.cloud
VITE_FIRM_NAME=Toxiro Abogados
VITE_FIRM_ICON=⚖️
VITE_ADMIN_EMAIL=admin@toxirodigital.cloud
VITE_APP_VERSION=v1.0

# === URLs de referencia (no son variables del compose) ===
# Frontend: https://abogados.toxirodigital.cloud
# Directus API: https://api.toxirodigital.cloud
# n8n (proyecto aparte): https://n8n.toxirodigital.cloud
